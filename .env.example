# MongoDB
MONGODB_URI=mongodb://localhost:27017/eventsdb

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Routing Service (defaults to local stub)
ROUTING_SERVICE_URL=http://localhost:3000/stub/route

# App environment
NODE_ENV=development
PORT=3000

# HMAC Secret (shared)
HMAC_SECRET=mysecret

# Optional: worker concurrency
WORKER_CONCURRENCY=10

# Optional: BullMQ queue names
EVENT_QUEUE_NAME=events
DLQ_QUEUE_NAME=events-dlq

# Idempotency TTL (in seconds)
IDEMPOTENCY_TTL=86400

